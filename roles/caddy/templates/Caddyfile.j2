# {{ ansible_managed }}
# Caddy Configuration
# Custom role for Debian 13 Trixie

# Global options
{
	email {{ caddy_email }}
{% if caddy_acme_ca | length > 0 %}
	skip_install_trust
{% endif %}
{% if not caddy_admin_enabled %}
	admin off
{% else %}
	admin {{ caddy_admin_address }}
{% endif %}
{% if caddy_metrics_enabled %}
	metrics {
{% if caddy_metrics_per_host %}
		per_host
{% endif %}
	}
	servers {
		metrics
	}
{% endif %}
}

# Virtual hosts - Reverse proxy with automatic HTTPS
{% for site in caddy_sites %}
{{ site.domain }} {
{% if caddy_acme_ca | length > 0 %}
	tls {
		ca {{ caddy_acme_ca }}
		ca_root {{ caddy_acme_ca_root }}
	}
{% endif %}
	reverse_proxy {{ site.backend }}
}

{% endfor %}
