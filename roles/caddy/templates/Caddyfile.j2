# {{ ansible_managed }}
# Caddy Configuration
# Custom role for Debian 13 Trixie

# Global options
{
	email {{ caddy_email }}
{% if caddy_acme_ca | length > 0 %}
	skip_install_trust
{% endif %}
{% if not caddy_admin_enabled %}
	admin off
{% else %}
	admin {{ caddy_admin_address }}
{% endif %}
{% if caddy_metrics_enabled %}
	metrics {
{% if caddy_metrics_per_host %}
		per_host
{% endif %}
	}
	servers {
		metrics
	}
{% endif %}
}

# Virtual hosts - Reverse proxy with automatic HTTPS
{% for site in caddy_sites %}
{{ site.domain }} {
{% if caddy_acme_ca | length > 0 %}
	tls {
		ca {{ caddy_acme_ca }}
		ca_root {{ caddy_acme_ca_root }}
	}
{% endif %}
	reverse_proxy {{ site.backend }}
{% if caddy_access_log_enabled %}
	log {
		output file {{ caddy_access_log_path }} {
			roll_size     {{ caddy_access_log_roll_size }}
			roll_keep     {{ caddy_access_log_roll_keep }}
			roll_keep_for {{ caddy_access_log_roll_keep_for }}
		}
		format json
	}
{% if caddy_access_log_skip_paths | length > 0 %}
	@health_probe path {{ caddy_access_log_skip_paths | join(' ') }}
	log_skip @health_probe
{% endif %}
{% endif %}
}

{% endfor %}
