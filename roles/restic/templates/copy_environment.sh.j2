# {{ ansible_managed }}
# Restic copy environment: {{ job.backup_name }} → {{ job.backend_name }}
# Generated by restic role - do not edit manually

# Source repository (local)
export RESTIC_FROM_REPOSITORY="{{ restic_repository }}"
export RESTIC_FROM_PASSWORD="{{ restic_password }}"

# Destination repository
{% if job.backend.type == 's3_compatible' %}
{% if job.copy.path is defined %}
export RESTIC_REPOSITORY="s3:{{ job.backend.endpoint }}/{{ job.backend.bucket }}/{{ job.copy.path }}"
{% else %}
export RESTIC_REPOSITORY="s3:{{ job.backend.endpoint }}/{{ job.backend.bucket }}"
{% endif %}
{% endif %}
export RESTIC_PASSWORD="{{ job.copy.password }}"

# Backend credentials
{% if job.backend.type == 's3_compatible' %}
export AWS_ACCESS_KEY_ID="{{ job.backend.key_id }}"
export AWS_SECRET_ACCESS_KEY="{{ job.backend.key_secret }}"
{% endif %}
