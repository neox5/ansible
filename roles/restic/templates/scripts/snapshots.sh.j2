#!/bin/bash
# {{ ansible_managed }}
# Restic list snapshots
# Usage: snapshot.sh <repo>

set -euo pipefail

source {{ restic_script_dir }}/lib.sh

REPO="${1:-}"

if [[ -z "$REPO" ]] || [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
  echo "Usage: $(basename "$0") <repo>"
  echo ""
  echo "Repositories:"
{% for repo_name in restic_repos %}
  echo "  {{ repo_name }}"
{% endfor %}
  [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]] && exit 0 || exit 1
fi

log_start "Snapshots: ${REPO}"

restic_run "$REPO" snapshots "${@:2}"

log_end "Snapshots: ${REPO}"
