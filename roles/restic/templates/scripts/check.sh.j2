#!/bin/bash
# {{ ansible_managed }}
# Restic repository check
# Usage: check.sh <repo>

set -euo pipefail

source {{ restic_script_dir }}/lib.sh

REPO="${1:-}"

if [[ -z "$REPO" ]]; then
  echo "Usage: $(basename "$0") <repo>"
  echo ""
  echo "Repositories:"
{% for repo_name, repo in restic_repos.items() %}
  echo "  {{ repo_name }}{% if repo.check is defined and repo.check.read_data_subset is defined %} (subset: {{ repo.check.read_data_subset }}){% endif %}"
{% endfor %}
  exit 1
fi

echo "=== Restic Check: ${REPO} ==="
echo "Started: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"

case "$REPO" in
{% for repo_name, repo in restic_repos.items() %}
  {{ repo_name }})
    env $(restic_env "{{ repo_name }}") \
      {{ restic_install_path }}/restic check \
{% if repo.check is defined and repo.check.read_data_subset is defined %}
      --read-data-subset {{ repo.check.read_data_subset }} \
{% endif %}
      "$@"
    ;;
{% endfor %}
  *)
    echo "Unknown repo: ${REPO}" >&2; exit 1 ;;
esac

echo ""
echo "Completed: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
echo "=== End Check: ${REPO} ==="
