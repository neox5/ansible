#!/bin/bash
# {{ ansible_managed }}
# Restic restore: {{ source_name }} from {{ repo_name }}

set -euo pipefail

source {{ restic_script_dir }}/env-{{ repo_name }}.sh

SNAPSHOT_ID="${1:-latest}"

{% if source.stdin | default(false) %}
# stdin source - dump to stdout for piping
echo "=== Restic Restore (stdout): {{ source_name }} from {{ repo_name }} ===" >&2
echo "Repository: $RESTIC_REPOSITORY" >&2
echo "Snapshot: $SNAPSHOT_ID" >&2
echo "File: {{ source.stdin_filename }}" >&2
echo "" >&2
echo "Usage: $0 [snapshot_id] | restore_command" >&2
echo "Example: $0 latest | sudo -u postgres pg_restore -d mydb --clean --if-exists" >&2
echo "" >&2

{{ restic_install_path }}/restic dump "$SNAPSHOT_ID" "/{{ source.stdin_filename }}"

{% else %}
# directory source - restore to filesystem
RESTORE_TARGET="${2:-{{ restic_restore_target }}}"

echo "=== Restic Restore (filesystem): {{ source_name }} from {{ repo_name }} ==="
echo "Repository: $RESTIC_REPOSITORY"
echo "Snapshot: $SNAPSHOT_ID"
echo "Target: $RESTORE_TARGET"
{% if source.paths is string %}
echo "Source: {{ source.paths }}"
{% else %}
echo "Sources:"
{% for path in source.paths %}
echo "  - {{ path }}"
{% endfor %}
{% endif %}
echo ""
echo "Usage: $0 [snapshot_id] [target_directory]"
echo ""

if [ ! -d "$RESTORE_TARGET" ]; then
  mkdir -p "$RESTORE_TARGET"
fi

{{ restic_install_path }}/restic restore "$SNAPSHOT_ID" \
  --target "$RESTORE_TARGET" \
{% if source.paths is string %}
  --path "{{ source.paths }}"
{% else %}
{% for path in source.paths %}
  --path "{{ path }}" \
{% endfor %}

{% endif %}
{% endif %}
