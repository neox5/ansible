#!/bin/bash
# {{ ansible_managed }}
# Restic copy between repositories
# Usage: copy.sh --from <repo> --to <repo> [--src <source>]

set -euo pipefail

source {{ restic_script_dir }}/lib.sh

FROM_REPO=""
TO_REPO=""
SOURCE_FILTER=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --from) FROM_REPO="$2"; shift 2 ;;
    --to)   TO_REPO="$2"; shift 2 ;;
    --src)  SOURCE_FILTER="$2"; shift 2 ;;
    -*)     echo "Unknown option: $1" >&2; exit 1 ;;
    *)      echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$FROM_REPO" ]] || [[ -z "$TO_REPO" ]]; then
  echo "Usage: $(basename "$0") --from <repo> --to <repo> [--src <source>]"
  echo ""
  echo "Repositories:"
{% for repo_name in restic_repos %}
  echo "  {{ repo_name }}"
{% endfor %}
  echo ""
  echo "Sources (optional filter):"
{% for source_name in restic_sources %}
  echo "  {{ source_name }}"
{% endfor %}
  exit 1
fi

echo "=== Restic Copy: ${FROM_REPO} → ${TO_REPO} ==="
echo "Started: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"

COPY_LOG="{{ restic_log_dir }}/copy-${FROM_REPO}-${TO_REPO}.log"
mkdir -p "$(dirname "$COPY_LOG")"

COPY_CMD=(env $(restic_from_env "$FROM_REPO") $(restic_env "$TO_REPO") \
  {{ restic_install_path }}/restic copy)

if [[ -n "$SOURCE_FILTER" ]]; then
  case "$SOURCE_FILTER" in
{% for source_name, source in restic_sources.items() %}
    {{ source_name }})
{% if source.stdin | default(false) %}
      COPY_CMD+=(--path "/{{ source.stdin_filename }}")
{% elif source.paths is string %}
      COPY_CMD+=(--path "{{ source.paths }}")
{% else %}
{% for path in source.paths %}
      COPY_CMD+=(--path "{{ path }}")
{% endfor %}
{% endif %}
      ;;
{% endfor %}
    *)
      echo "Unknown source: ${SOURCE_FILTER}" >&2; exit 1 ;;
  esac
fi

COPY_EXIT=0
"${COPY_CMD[@]}" 2>&1 | tee -a "$COPY_LOG" || COPY_EXIT=$?

if [[ $COPY_EXIT -ne 0 ]]; then
  echo "Copy FAILED (exit ${COPY_EXIT})" | tee -a "$COPY_LOG"
  exit $COPY_EXIT
fi

echo "Copy SUCCESS" | tee -a "$COPY_LOG"
echo "Completed: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
