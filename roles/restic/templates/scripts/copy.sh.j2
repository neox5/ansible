#!/bin/bash
# {{ ansible_managed }}
# Restic copy between repositories
# Usage: copy.sh --from <repo> --to <repo> [--src <source>]

set -euo pipefail

source {{ restic_script_dir }}/lib.sh

FROM_REPO=""
TO_REPO=""
SOURCE_FILTER=""

show_usage() {
  local out="${1:-stdout}"
  local fd=1; [[ "$out" == "stderr" ]] && fd=2
  echo "Usage: $(basename "$0") --from <repo> --to <repo> [--src <source>]" >&$fd
  echo "" >&$fd
  echo "Repositories:" >&$fd
{% for repo_name in restic_repos %}
  echo "  {{ repo_name }}" >&$fd
{% endfor %}
  echo "" >&$fd
  echo "Sources (optional filter):" >&$fd
{% for source_name in restic_sources %}
  echo "  {{ source_name }}" >&$fd
{% endfor %}
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --from) FROM_REPO="$2"; shift 2 ;;
    --to)   TO_REPO="$2"; shift 2 ;;
    --src)  SOURCE_FILTER="$2"; shift 2 ;;
    -h|--help) show_usage stdout; exit 0 ;;
    -*)     echo "Unknown option: $1" >&2; exit 1 ;;
    *)      echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$FROM_REPO" ]] || [[ -z "$TO_REPO" ]]; then
  show_usage stderr
  exit 1
fi

log_start "Copy: ${FROM_REPO} → ${TO_REPO}"

COPY_LOG="{{ restic_log_dir }}/copy-${FROM_REPO}-${TO_REPO}.log"
mkdir -p "$(dirname "$COPY_LOG")"

COPY_ARGS=()

if [[ -n "$SOURCE_FILTER" ]]; then
  case "$SOURCE_FILTER" in
{% for source_name, source in restic_sources.items() %}
    {{ source_name }})
{% if source.stdin | default(false) %}
      COPY_ARGS+=(--path "/{{ source.stdin_filename }}")
{% elif source.paths is string %}
      COPY_ARGS+=(--path "{{ source.paths }}")
{% else %}
{% for path in source.paths %}
      COPY_ARGS+=(--path "{{ path }}")
{% endfor %}
{% endif %}
      ;;
{% endfor %}
    *)
      echo "Unknown source: ${SOURCE_FILTER}" >&2; exit 1 ;;
  esac
fi

COPY_EXIT=0
restic_run_from "$FROM_REPO" "$TO_REPO" copy "${COPY_ARGS[@]}" \
  2>&1 | tee -a "$COPY_LOG" || COPY_EXIT=$?

log_result $COPY_EXIT "copy: ${FROM_REPO} → ${TO_REPO}" "$COPY_LOG" || exit $COPY_EXIT

log_end "Copy: ${FROM_REPO} → ${TO_REPO}"
