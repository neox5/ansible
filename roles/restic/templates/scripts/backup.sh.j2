#!/bin/bash
# {{ ansible_managed }}
# Restic backup job: {{ item.key }}

set -euo pipefail

source {{ restic_script_dir }}/env-{{ item.value.repo }}.sh

OVERALL_EXIT=0

{% for source_name in item.value.sources %}
{% set source = restic_sources[source_name] %}
{% set repo = restic_repos[item.value.repo] %}
{% set retention = repo.retention | default(restic_retention) %}
# --- Source: {{ source_name }} ---
echo "=== Backup: {{ source_name }} → {{ item.value.repo }} ==="
echo "Started: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"

BACKUP_LOG="{{ restic_log_dir }}/{{ item.key }}/{{ source_name }}-backup.log"
FORGET_LOG="{{ restic_log_dir }}/{{ item.key }}/{{ source_name }}-forget.log"

BACKUP_EXIT=0
{% if source.stdin | default(false) %}
{{ source.stdin_command }} | {{ restic_install_path }}/restic backup \
  --stdin \
  --stdin-filename "{{ source.stdin_filename }}" \
{% else %}
{{ restic_install_path }}/restic backup \
{% if source.paths is string %}
  {{ source.paths }} \
{% else %}
{% for path in source.paths %}
  {{ path }} \
{% endfor %}
{% endif %}
{% if source.exclude is defined %}
{% for pattern in source.exclude %}
  --exclude "{{ pattern }}" \
{% endfor %}
{% endif %}
{% endif %}
{% for tag in source.tags | default([]) %}
  --tag {{ tag }} \
{% endfor %}
{% for tag in item.value.tags | default([]) %}
  --tag {{ tag }} \
{% endfor %}
  "$@" 2>&1 | tee -a "$BACKUP_LOG" || BACKUP_EXIT=$?

if [ $BACKUP_EXIT -ne 0 ]; then
  echo "Backup FAILED: {{ source_name }} (exit code $BACKUP_EXIT)" | tee -a "$BACKUP_LOG"
  OVERALL_EXIT=1
{% if item.value.on_failure | default('continue') == 'stop' %}
  exit 1
{% endif %}
else
  echo "Backup SUCCESS: {{ source_name }}" | tee -a "$BACKUP_LOG"

  FORGET_EXIT=0
  {{ restic_install_path }}/restic forget \
{% if source.stdin | default(false) %}
    --path "/{{ source.stdin_filename }}" \
{% elif source.paths is string %}
    --path "{{ source.paths }}" \
{% else %}
{% for path in source.paths %}
    --path "{{ path }}" \
{% endfor %}
{% endif %}
{% if retention.keep_last is defined and retention.keep_last %}
    --keep-last {{ retention.keep_last }} \
{% endif %}
{% if retention.keep_hourly is defined and retention.keep_hourly %}
    --keep-hourly {{ retention.keep_hourly }} \
{% endif %}
{% if retention.keep_daily is defined and retention.keep_daily %}
    --keep-daily {{ retention.keep_daily }} \
{% endif %}
{% if retention.keep_weekly is defined and retention.keep_weekly %}
    --keep-weekly {{ retention.keep_weekly }} \
{% endif %}
{% if retention.keep_monthly is defined and retention.keep_monthly %}
    --keep-monthly {{ retention.keep_monthly }} \
{% endif %}
{% if retention.keep_yearly is defined and retention.keep_yearly %}
    --keep-yearly {{ retention.keep_yearly }} \
{% endif %}
{% if retention.keep_within is defined and retention.keep_within %}
    --keep-within {{ retention.keep_within }} \
{% endif %}
{% if retention.prune | default(false) %}
    --prune \
{% endif %}
    2>&1 | tee -a "$FORGET_LOG" || FORGET_EXIT=$?

  if [ $FORGET_EXIT -ne 0 ]; then
    echo "Forget FAILED: {{ source_name }} (exit code $FORGET_EXIT)" | tee -a "$FORGET_LOG"
    OVERALL_EXIT=1
{% if item.value.on_failure | default('continue') == 'stop' %}
    exit 1
{% endif %}
  else
    echo "Forget SUCCESS: {{ source_name }}" | tee -a "$FORGET_LOG"
  fi
fi

echo "Completed: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
echo ""
{% endfor %}

exit $OVERALL_EXIT
