# {{ ansible_managed }}
# Rclone configuration - generated by Ansible restic role
# Do not edit manually

{% for repo_name, repo in restic_repos.items() %}
{% if repo.backend | first == 's3' %}
[{{ repo_name }}]
type = s3
provider = {{ repo.backend.s3.provider | default('Other') }}
access_key_id = {{ repo.backend.s3.key_id }}
secret_access_key = {{ repo.backend.s3.key_secret }}
endpoint = {{ repo.backend.s3.endpoint }}
{% if repo.backend.s3.region is defined %}
region = {{ repo.backend.s3.region }}
{% endif %}

{% endif %}
{% endfor %}
