#!/bin/bash
# {{ ansible_managed }}
# Restic copy script: {{ job.backup_name }} → {{ job.backend_name }}
# Part of restic role

set -euo pipefail

# Source copy environment
source {{ restic_script_dir }}/copy-env-{{ job.backup_name }}-{{ job.backend_name }}.sh

COPY_LOG="{{ restic_log_dir }}/{{ job.backup_name }}/copy-{{ job.backend_name }}.log"
FORGET_LOG="{{ restic_log_dir }}/{{ job.backup_name }}/copy-{{ job.backend_name }}-forget.log"

echo "=== Restic Copy: {{ job.backup_name }} → {{ job.backend_name }} ===" | tee -a "$COPY_LOG"
echo "Started: $(date -u '+%Y-%m-%d %H:%M:%S UTC')" | tee -a "$COPY_LOG"
echo "Source:      $RESTIC_FROM_REPOSITORY" | tee -a "$COPY_LOG"
echo "Destination: $RESTIC_REPOSITORY" | tee -a "$COPY_LOG"
echo "" | tee -a "$COPY_LOG"

COPY_EXIT_CODE=0
{{ restic_install_path }}/restic copy \
  --from-repo "$RESTIC_FROM_REPOSITORY" \
{% if job.stdin %}
  --path "/{{ job.stdin_filename }}" \
{% elif job.paths is string %}
  --path "{{ job.paths }}" \
{% else %}
{% for path in job.paths %}
  --path "{{ path }}" \
{% endfor %}
{% endif %}
  "$@" 2>&1 | tee -a "$COPY_LOG" || COPY_EXIT_CODE=$?

echo "" | tee -a "$COPY_LOG"
if [ $COPY_EXIT_CODE -eq 0 ]; then
  echo "Copy: SUCCESS" | tee -a "$COPY_LOG"
else
  echo "Copy: FAILED (exit code $COPY_EXIT_CODE)" | tee -a "$COPY_LOG"
  exit $COPY_EXIT_CODE
fi

# Retention policy enforcement on destination repository
echo "" | tee -a "$FORGET_LOG"
echo "=== Retention Policy (remote): {{ job.backup_name }} → {{ job.backend_name }} ===" | tee -a "$FORGET_LOG"
echo "Started: $(date -u '+%Y-%m-%d %H:%M:%S UTC')" | tee -a "$FORGET_LOG"

FORGET_EXIT_CODE=0
{{ restic_install_path }}/restic forget \
{% if job.stdin %}
  --path "/{{ job.stdin_filename }}" \
{% elif job.paths is string %}
  --path "{{ job.paths }}" \
{% else %}
{% for path in job.paths %}
  --path "{{ path }}" \
{% endfor %}
{% endif %}
{% if job.copy.keep_last is defined %}
  --keep-last {{ job.copy.keep_last }} \
{% elif job.backup.keep_last is defined %}
  --keep-last {{ job.backup.keep_last }} \
{% elif restic_keep_last is not none %}
  --keep-last {{ restic_keep_last }} \
{% endif %}
{% if job.copy.keep_hourly is defined %}
  --keep-hourly {{ job.copy.keep_hourly }} \
{% elif job.backup.keep_hourly is defined %}
  --keep-hourly {{ job.backup.keep_hourly }} \
{% elif restic_keep_hourly is not none %}
  --keep-hourly {{ restic_keep_hourly }} \
{% endif %}
{% if job.copy.keep_daily is defined %}
  --keep-daily {{ job.copy.keep_daily }} \
{% elif job.backup.keep_daily is defined %}
  --keep-daily {{ job.backup.keep_daily }} \
{% elif restic_keep_daily is not none %}
  --keep-daily {{ restic_keep_daily }} \
{% endif %}
{% if job.copy.keep_weekly is defined %}
  --keep-weekly {{ job.copy.keep_weekly }} \
{% elif job.backup.keep_weekly is defined %}
  --keep-weekly {{ job.backup.keep_weekly }} \
{% elif restic_keep_weekly is not none %}
  --keep-weekly {{ restic_keep_weekly }} \
{% endif %}
{% if job.copy.keep_monthly is defined %}
  --keep-monthly {{ job.copy.keep_monthly }} \
{% elif job.backup.keep_monthly is defined %}
  --keep-monthly {{ job.backup.keep_monthly }} \
{% elif restic_keep_monthly is not none %}
  --keep-monthly {{ restic_keep_monthly }} \
{% endif %}
{% if job.copy.keep_yearly is defined %}
  --keep-yearly {{ job.copy.keep_yearly }} \
{% elif job.backup.keep_yearly is defined %}
  --keep-yearly {{ job.backup.keep_yearly }} \
{% elif restic_keep_yearly is not none %}
  --keep-yearly {{ restic_keep_yearly }} \
{% endif %}
{% if job.copy.keep_within is defined %}
  --keep-within {{ job.copy.keep_within }} \
{% elif job.backup.keep_within is defined %}
  --keep-within {{ job.backup.keep_within }} \
{% elif restic_keep_within is not none %}
  --keep-within {{ restic_keep_within }} \
{% endif %}
{% if job.copy.prune | default(job.backup.prune | default(restic_copy_prune)) %}
  --prune \
{% endif %}
  2>&1 | tee -a "$FORGET_LOG" || FORGET_EXIT_CODE=$?

if [ $FORGET_EXIT_CODE -eq 0 ]; then
  echo "Forget (remote): SUCCESS" | tee -a "$FORGET_LOG"
else
  echo "Forget (remote): FAILED (exit code $FORGET_EXIT_CODE)" | tee -a "$FORGET_LOG"
  exit $FORGET_EXIT_CODE
fi

echo "Completed: $(date -u '+%Y-%m-%d %H:%M:%S UTC')" | tee -a "$COPY_LOG"
echo "=== End Copy: {{ job.backup_name }} → {{ job.backend_name }} ===" | tee -a "$COPY_LOG"
