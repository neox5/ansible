#!/bin/bash
# {{ ansible_managed }}
# PostgreSQL Restore Script
# Location: {{ postgresql_scripts_dir }}/pg_restore.sh
# Part of postgresql role - shares inventory variables as defaults

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults (from Ansible inventory - overridable via environment variables)
# ---------------------------------------------------------------------------
PG_USER="${PGUSER:-{{ postgresql_admin_user }}}"
PG_PORT="${PGPORT:-{{ postgresql_port }}}"

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
DATABASE=""
BACKUP_FILE=""
SKIP_CONFIRM=false

usage() {
    cat <<EOF
Usage: $(basename "$0") [options] <database> --dump <file>

Restore a PostgreSQL database from a pg_dump backup.

Arguments:
    database         Target database name

Options:
    --dump, --file   Path to the backup dump file (required)
    -y, --yes        Skip confirmation prompt (for automation)
    -h, --help       Show this help message and exit

Environment Variables (override compiled-in defaults):
    PGUSER           PostgreSQL user  (default: $PG_USER)
    PGPORT           PostgreSQL port  (default: $PG_PORT)

Notes:
    - Target database must already exist
    - This will DROP and recreate all objects in the database
    - Use with caution on production systems

Examples:
    $(basename "$0") n8n --dump {{ postgresql_backup_dir }}/n150-01-n8n-20260215T120000.dump
    $(basename "$0") n8n --dump /tmp/backup.dump --yes
    PGUSER=postgres $(basename "$0") n8n --dump /tmp/backup.dump
EOF
}

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage
            exit 0
            ;;
        -y|--yes)
            SKIP_CONFIRM=true
            shift
            ;;
        --dump|--file)
            if [[ -z "${2:-}" ]]; then
                echo "Error: $1 requires a file path argument" >&2
                usage >&2
                exit 1
            fi
            BACKUP_FILE="$2"
            shift 2
            ;;
        -*)
            echo "Error: Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            if [[ -z "$DATABASE" ]]; then
                DATABASE="$1"
            else
                echo "Error: Unexpected argument: $1" >&2
                usage >&2
                exit 1
            fi
            shift
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Validate required arguments
# ---------------------------------------------------------------------------
if [[ -z "$DATABASE" ]] || [[ -z "$BACKUP_FILE" ]]; then
    echo "Error: Both <database> and --dump <file> are required" >&2
    usage >&2
    exit 1
fi

if [[ ! -f "$BACKUP_FILE" ]]; then
    echo "Error: Backup file not found: $BACKUP_FILE" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Restore
# ---------------------------------------------------------------------------
BACKUP_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
echo "=== PostgreSQL Restore ==="
echo "Backup file:     $BACKUP_FILE"
echo "Backup size:     $BACKUP_SIZE"
echo "Target database: $DATABASE"
echo ""

# Verify database exists
echo "Verifying target database exists..."
if ! psql \
    --username="$PG_USER" \
    --port="$PG_PORT" \
    --dbname=postgres \
    --tuples-only \
    --no-align \
    --command="SELECT 1 FROM pg_database WHERE datname='$DATABASE'" | grep -q 1; then
    echo "Error: Database '$DATABASE' does not exist" >&2
    echo "Create it first with: sudo -u postgres createdb $DATABASE" >&2
    exit 1
fi

echo "Database '$DATABASE' found"
echo ""

# Confirm
if [[ "$SKIP_CONFIRM" == "false" ]]; then
    read -r -p "WARNING: This will overwrite data in '$DATABASE'. Continue? (yes/no): " CONFIRM
    if [[ "$CONFIRM" != "yes" ]]; then
        echo "Restore cancelled"
        exit 0
    fi
else
    echo "Skipping confirmation (--yes flag provided)"
fi

# Perform restore
echo ""
echo "Starting restore..."
echo "+ pg_restore --username=$PG_USER --port=$PG_PORT --dbname=$DATABASE --clean --if-exists --verbose $BACKUP_FILE" >&2
RESTORE_EXIT=0
pg_restore \
    --username="$PG_USER" \
    --port="$PG_PORT" \
    --dbname="$DATABASE" \
    --clean \
    --if-exists \
    --verbose \
    "$BACKUP_FILE" 2>&1 | grep -v "^$" || RESTORE_EXIT=$?

if [[ $RESTORE_EXIT -ne 0 ]]; then
    echo ""
    echo "Error: Restore failed with exit code $RESTORE_EXIT" >&2
    exit $RESTORE_EXIT
fi

echo ""
echo "=== Restore Complete ==="
echo "Database '$DATABASE' restored from: $BACKUP_FILE"
